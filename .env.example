# ── Configuración de conexión a Odoo 18 ──────────────────────────────────────
# Copiar este archivo como .env y completar con tus datos reales
# NUNCA subir el archivo .env a un repositorio de código

# URL de tu instancia Odoo (sin barra final)
ODOO_URL=https://tu-empresa.odoo.com

# Nombre de la base de datos
ODOO_DB=nombre_de_tu_base

# ID de usuario (ver: Ajustes → Usuarios → tu usuario → ID en la URL)
ODOO_UID=2

# Clave API o contraseña
# Recomendado: usar API Key (Ajustes → Usuarios → Seguridad → Generar clave API)
ODOO_PWD=tu_api_key_aqui

# ── Modo de operación ─────────────────────────────────────────────────────────
# true  → Datos simulados, sin conexión a Odoo (para desarrollo y demos)
# false → Conexión real a Odoo usando las credenciales de arriba
DEMO_MODE=true
