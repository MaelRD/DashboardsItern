# Nombre de la base de datos
ODOO_DB=odoo-ps-psmx-brandin-main-18121349

# Usuario
ODOO_UID=soporte-odoo@customizecpa.com

# Clave API o contraseña
ODOO_PWD=cb047925626138a9444fc1f8608d10302419f7be

# ── Modo de operación ─────────────────────────────────────────────────────────
# true  → Datos simulados, sin conexión a Odoo (para desarrollo y demos)
# false → Conexión real a Odoo usando las credenciales de arriba
DEMO_MODE=false
